# ─────────────────────────────────────────────
# diggr.ai — Environment Configuration
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# ── Application ──
NODE_ENV=development
APP_NAME=diggr-ai
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://diggr:diggr_dev_password@localhost:5432/diggr_dev?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diggr_dev
DB_USER=diggr
DB_PASSWORD=diggr_dev_password

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth (Auth0) ──
AUTH0_DOMAIN=your-tenant.uk.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://api.diggr.ai
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/callback
AUTH0_MANAGEMENT_API_TOKEN=your_management_token

# ── Auth (Next.js) ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32

# ── AWS ──
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=diggr-documents-dev
AWS_S3_ENDPOINT=http://localhost:9000

# ── AI / LLM ──
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key_fallback
AI_CONFIDENCE_THRESHOLD=0.85
AI_SUPPRESS_THRESHOLD=0.70

# ── Document Processing ──
AWS_TEXTRACT_ENABLED=false

# ── Email ──
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@diggr.ai

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ── Logging ──
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ── CORS ──
CORS_ORIGINS=http://localhost:3000
